<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="12" style="-fx-background-color: #0d1117; -fx-padding: 20;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="vue.VueController">

    <!-- TITRE -->
    <Label text="✈  Gestion des Aéroports"
           style="-fx-font-size: 22px; -fx-font-weight: bold;
                  -fx-text-fill: #58a6ff; -fx-padding: 0 0 10 0;"/>

    <Separator style="-fx-background-color: #21262d;"/>

    <!-- FORMULAIRE -->
    <HBox spacing="10">
        <TextField fx:id="txtNumeroVol" promptText="Numéro de vol"
                   style="-fx-background-color: #161b22; -fx-text-fill: #c9d1d9;
                          -fx-border-color: #30363d; -fx-border-radius: 5;
                          -fx-background-radius: 5; -fx-padding: 8;
                          -fx-prompt-text-fill: #484f58;" prefWidth="130"/>
        <TextField fx:id="txtDestination" promptText="Destination"
                   style="-fx-background-color: #161b22; -fx-text-fill: #c9d1d9;
                          -fx-border-color: #30363d; -fx-border-radius: 5;
                          -fx-background-radius: 5; -fx-padding: 8;
                          -fx-prompt-text-fill: #484f58;" prefWidth="130"/>
        <TextField fx:id="txtCompagnie" promptText="Compagnie"
                   style="-fx-background-color: #161b22; -fx-text-fill: #c9d1d9;
                          -fx-border-color: #30363d; -fx-border-radius: 5;
                          -fx-background-radius: 5; -fx-padding: 8;
                          -fx-prompt-text-fill: #484f58;" prefWidth="130"/>
        <ComboBox fx:id="cmbTypeVol" promptText="Type de vol"
                  style="-fx-background-color: #161b22; -fx-text-fill: #c9d1d9;
                         -fx-border-color: #30363d; -fx-border-radius: 5;
                         -fx-background-radius: 5;" prefWidth="140"/>
        <TextField fx:id="txtPlaces" promptText="Places"
                   style="-fx-background-color: #161b22; -fx-text-fill: #c9d1d9;
                          -fx-border-color: #30363d; -fx-border-radius: 5;
                          -fx-background-radius: 5; -fx-padding: 8;
                          -fx-prompt-text-fill: #484f58;" prefWidth="80"/>
        <CheckBox fx:id="chkStatut" text="Disponible"
                  style="-fx-text-fill: #c9d1d9;"/>
    </HBox>

    <!-- BOUTONS -->
    <HBox spacing="10">
        <Button text="＋  Ajouter" onAction="#ajouter"
                style="-fx-background-color: #1f6feb; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-border-radius: 5;
                       -fx-background-radius: 5; -fx-padding: 8 16;
                       -fx-cursor: hand;"/>
        <Button text="✎  Modifier" onAction="#modifier"
                style="-fx-background-color: #388bfd26; -fx-text-fill: #58a6ff;
                       -fx-border-color: #1f6feb; -fx-border-radius: 5;
                       -fx-background-radius: 5; -fx-padding: 8 16;
                       -fx-cursor: hand;"/>
        <Button text="✕  Supprimer" onAction="#supprimer"
                style="-fx-background-color: #da363326; -fx-text-fill: #f85149;
                       -fx-border-color: #da3633; -fx-border-radius: 5;
                       -fx-background-radius: 5; -fx-padding: 8 16;
                       -fx-cursor: hand;"/>
        <Button text="↺  Actualiser" onAction="#actualiser"
                style="-fx-background-color: #21262d; -fx-text-fill: #8b949e;
                       -fx-border-color: #30363d; -fx-border-radius: 5;
                       -fx-background-radius: 5; -fx-padding: 8 16;
                       -fx-cursor: hand;"/>
    </HBox>

    <Separator style="-fx-background-color: #21262d;"/>

    <!-- RECHERCHE -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="🔍" style="-fx-text-fill: #8b949e; -fx-font-size: 14;"/>
        <TextField fx:id="txtRecherche" promptText="Rechercher par destination ou type..."
                   onKeyReleased="#rechercher"
                   style="-fx-background-color: #161b22; -fx-text-fill: #c9d1d9;
                          -fx-border-color: #30363d; -fx-border-radius: 5;
                          -fx-background-radius: 5; -fx-padding: 8;
                          -fx-prompt-text-fill: #484f58;" prefWidth="350"/>
    </HBox>

    <!-- TABLEAU -->
    <TableView fx:id="tableVols" prefHeight="420"
               style="-fx-background-color: #161b22; -fx-border-color: #30363d;
                      -fx-border-radius: 5; -fx-table-cell-border-color: #21262d;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="45"/>
            <TableColumn fx:id="colNumero" text="Numéro Vol" prefWidth="110"/>
            <TableColumn fx:id="colDestination" text="Destination" prefWidth="120"/>
            <TableColumn fx:id="colCompagnie" text="Compagnie" prefWidth="140"/>
            <TableColumn fx:id="colType" text="Type" prefWidth="110"/>
            <TableColumn fx:id="colPlaces" text="Places" prefWidth="70"/>
            <TableColumn fx:id="colStatut" text="Statut" prefWidth="80"/>
        </columns>
        <placeholder>
            <Label text="Aucun vol trouvé"
                   style="-fx-text-fill: #484f58; -fx-font-size: 13;"/>
        </placeholder>
    </TableView>

</VBox>